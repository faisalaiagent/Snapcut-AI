# ============================================================
# STEP 1 — Copy this file: rename it to .env.local
# STEP 2 — Fill in each value below
# STEP 3 — Restart npm run dev after saving
# ============================================================

# ── REQUIRED TO START THE APP ────────────────────────────────

# Your app URL (keep this for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Generate this secret by running in terminal:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=paste-your-generated-secret-here

# ── SUPABASE (required) ──────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CLOUDINARY (required for image upload) ───────────────────
# Get from: https://cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret

# ── REMOVE.BG (required for background removal) ──────────────
# Get from: https://www.remove.bg/api → API Keys
REMOVE_BG_API_KEY=your_remove_bg_api_key

# ── GOOGLE LOGIN (optional for local dev) ────────────────────
# Get from: https://console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── RESEND EMAIL (optional for local dev) ────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=
CONTACT_EMAIL=support@yourdomain.com

# ── STRIPE (optional for local dev) ──────────────────────────
# Get from: https://stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRO_PRICE_ID=price_
STRIPE_BUSINESS_PRICE_ID=price_
